# ─── Google Sheets — Service Account auth ────────────────────────────
# Sheet ID จาก URL: .../spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# จาก JSON key file ที่ download มา (client_email)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com

# จาก JSON key file (private_key) — ใส่ทั้ง block ในเครื่องหมาย " "
# ให้คง \n ไว้ ห้ามขึ้นบรรทัดใหม่จริงใน .env
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# gid ของ Tab (ดูจาก URL: ...#gid=XXXXXXXXX)
SHEET_GID=0

# (optional) ถ้ารู้ชื่อ Tab โดยตรง จะเร็วกว่า (ไม่ต้อง resolve)
# SHEET_NAME=Sheet1

# Index คอลัมน์ ID (0 = A, 1 = B, ...)
ID_COLUMN_INDEX=0
